---
import Layout from "../layouts/Layout.astro"
import WorkCard from "../components/WorkCard.astro"
import work_data from "../data/work.json"
---

<Layout title="work">
	<section class="space-y-8">
		<h1
			class="text-3xl font-bold animate-blur-reveal opacity-0"
			style="animation-delay: 100ms;">
			my work
		</h1>
		{
			work_data.map((work, i) => (
				<div
                    class="animate-blur-reveal opacity-0"}
                    style={`animation-delay: ${150 + i * 50}ms`}
                    >
					<WorkCard {work} />
				</div>
			))
		}
	</section>
</Layout>
